{
  "ConnectionStrings": {
    "Oloraculo": "Data Source=/var/oloraculo/oloraculo.db"
  },
  "Oloraculo": {
    "RankingRefreshOnStartup": false,
    "ObjectArchive": {
      "Enabled": false,
      "Provider": "R2",
      "Bucket": "",
      "Endpoint": "",
      "Region": "auto",
      "Prefix": "oloraculo",
      "ForcePathStyle": true,
      "BucketEnvironmentVariable": "OLORACULO_R2_BUCKET",
      "EndpointEnvironmentVariable": "OLORACULO_R2_ENDPOINT",
      "RegionEnvironmentVariable": "AWS_REGION",
      "AccessKeyIdEnvironmentVariable": "OLORACULO_R2_ACCESS_KEY_ID",
      "SecretAccessKeyEnvironmentVariable": "OLORACULO_R2_SECRET_ACCESS_KEY"
    }
  }
}
