@page "/data"
@rendermode InteractiveServer
@inject CsvImportService Importer
@inject RankingRefreshService Rankings
@inject ApiFootballService Api
@inject AvailabilityNewsService Availability
@inject OloraculoDbContext Db
@inject ISnackbar Snackbar

<PageTitle>Data</PageTitle>

<MudStack Spacing="3">
    <div class="page-head">
        <MudText Typo="Typo.h3">Data</MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary">CSV import status and optional API-Football refreshes.</MudText>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_error</MudAlert>
    }

    <MudPaper Class="surface-card" Elevation="0">
        <MudStack Row="true" Spacing="1" Class="action-row">
            <BusyButton Text="Reimport CSV" BusyText="Importing" IsBusy="_busy" Icon="@Icons.Material.Filled.UploadFile" OnClick="ImportAll" />
            <BusyButton Text="Refresh rankings" BusyText="Refreshing" IsBusy="_rankingsBusy" Variant="Variant.Outlined" Color="Color.Secondary" Icon="@Icons.Material.Filled.Sync" OnClick="RefreshRankings" />
            <BusyButton Text="Refresh API-Football matches" BusyText="Refreshing" IsBusy="_apiBusy" Variant="Variant.Outlined" Color="Color.Secondary" Icon="@Icons.Material.Filled.CloudSync" OnClick="RefreshApi" />
            <BusyButton Text="Refresh availability" BusyText="Analyzing" IsBusy="_availabilityBusy" Variant="Variant.Outlined" Color="Color.Secondary" Icon="@Icons.Material.Filled.FactCheck" OnClick="RefreshAvailability" />
        </MudStack>
        @if (_busy || _rankingsBusy || _apiBusy || _availabilityBusy)
        {
            <MudProgressLinear Class="inline-progress" Color="Color.Primary" Indeterminate="true" />
        }
        @if (_report is not null)
        {
            <MudAlert Class="mt-2" Severity="Severity.Success" Variant="Variant.Outlined">@_report.Teams teams, @_report.Groups groups, @_report.Fixtures fixtures, @_report.Results results, @_report.Ratings ratings.</MudAlert>
        }
        @if (_rankingsReport is not null)
        {
            <MudAlert Class="mt-2" Severity="@(_rankingsReport.Errors.Count > 0 ? Severity.Warning : Severity.Info)" Variant="Variant.Outlined">
                @string.Join(" ", _rankingsReport.Notes)
                @if (_rankingsReport.AnyFileUpdated)
                {
                    <span> Updated files: @string.Join(", ", _rankingsReport.UpdatedFiles). Imported ratings: @_ratings.</span>
                }
            </MudAlert>
            @foreach (var error in _rankingsReport.Errors)
            {
                <MudAlert Class="mt-2" Severity="Severity.Warning" Variant="Variant.Outlined">@error</MudAlert>
            }
        }
        @if (_apiReport is not null)
        {
            <MudAlert Class="mt-2" Severity="@(_apiReport.Errors.Count > 0 ? Severity.Warning : Severity.Info)" Variant="Variant.Outlined">API-enriched impacts: @_apiReport.ImpactMatchedPlayers. Position fallback: @_apiReport.ImpactFallbackPlayers. @string.Join(" ", _apiReport.Notes)</MudAlert>
            @foreach (var error in _apiReport.Errors)
            {
                <MudAlert Class="mt-2" Severity="Severity.Warning" Variant="Variant.Outlined">@error</MudAlert>
            }
        }
        @if (_availabilityReport is not null)
        {
            <MudAlert Class="mt-2" Severity="@(_availabilityReport.Errors.Count > 0 ? Severity.Warning : Severity.Info)" Variant="Variant.Outlined">
                Sources fetched: @_availabilityReport.SourcesFetched. Sources skipped: @_availabilityReport.SourcesSkipped. Claims saved: @_availabilityReport.ClaimsSaved. Confirmed out: @_availabilityReport.ConfirmedOutClaims. Doubtful: @_availabilityReport.DoubtfulClaims. Available: @_availabilityReport.AvailableClaims. Claims affecting predictions: @_availabilityReport.ClaimsAffectingPredictions. Matched roles: @_availabilityReport.RoleMatchedClaims. Unknown roles: @_availabilityReport.RoleUnknownClaims. Enriched impacts: @_availabilityReport.ImpactMatchedClaims. Position fallback: @_availabilityReport.ImpactFallbackClaims. Updated contexts: @_availabilityReport.ContextRowsUpdated. @string.Join(" ", _availabilityReport.Notes)
            </MudAlert>
            @foreach (var error in _availabilityReport.Errors)
            {
                <MudAlert Class="mt-2" Severity="Severity.Warning" Variant="Variant.Outlined">@error</MudAlert>
            }
        }
        @if (_roleReport is not null)
        {
            <MudAlert Class="mt-2" Severity="@(_roleReport.Errors.Count > 0 ? Severity.Warning : Severity.Info)" Variant="Variant.Outlined">
                Role enrichment: @_roleReport.RoleMatchedClaims matched, @_roleReport.RoleUnknownClaims unknown. Enriched impacts: @_roleReport.ImpactMatchedClaims. Position fallback: @_roleReport.ImpactFallbackClaims. @string.Join(" ", _roleReport.Notes)
            </MudAlert>
            @foreach (var error in _roleReport.Errors)
            {
                <MudAlert Class="mt-2" Severity="Severity.Warning" Variant="Variant.Outlined">@error</MudAlert>
            }
        }
    </MudPaper>

    <MudGrid Spacing="2">
        <MudItem xs="12" md="4"><MudPaper Class="stat-card" Elevation="0"><MudText Typo="Typo.h4">@_teams</MudText><MudText Typo="Typo.body2" Color="Color.Secondary">Teams</MudText></MudPaper></MudItem>
        <MudItem xs="12" md="4"><MudPaper Class="stat-card" Elevation="0"><MudText Typo="Typo.h4">@_fixtures</MudText><MudText Typo="Typo.body2" Color="Color.Secondary">Matches</MudText></MudPaper></MudItem>
        <MudItem xs="12" md="4"><MudPaper Class="stat-card" Elevation="0"><MudText Typo="Typo.h4">@_ratings</MudText><MudText Typo="Typo.body2" Color="Color.Secondary">Ratings</MudText></MudPaper></MudItem>
    </MudGrid>

    <MudPaper Class="surface-card" Elevation="0">
        <MudText Typo="Typo.h6">Ratings</MudText>
        @if (!_loaded)
        {
            <MudSkeleton Height="34px" Class="skeleton-row" />
            <MudSkeleton Height="34px" Class="skeleton-row" />
            <MudSkeleton Height="34px" Class="skeleton-row" />
        }
        else
        {
            <MudTable Items="_ratingRows" Dense="true" Hover="true" Elevation="0" Class="dense-table">
                <HeaderContent>
                    <MudTh>Team</MudTh>
                    <MudTh>Type</MudTh>
                    <MudTh Class="num">Value</MudTh>
                    <MudTh>Source</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Team"><TeamLabel TeamId="@context.TeamId" Name="@Name(context.TeamId)" /></MudTd>
                    <MudTd DataLabel="Type">@context.Type</MudTd>
                    <MudTd DataLabel="Value" Class="num">@context.Value.ToString("0")</MudTd>
                    <MudTd DataLabel="Source">@context.Source</MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudPaper>
</MudStack>

@code {
    private bool _busy;
    private bool _apiBusy;
    private bool _rankingsBusy;
    private bool _availabilityBusy;
    private bool _loaded;
    private CsvImportReport? _report;
    private RankingRefreshReport? _rankingsReport;
    private ApiFootballRefreshReport? _apiReport;
    private AvailabilityRefreshReport? _availabilityReport;
    private AvailabilityRefreshReport? _roleReport;
    private int _teams;
    private int _fixtures;
    private int _ratings;
    private List<Rating> _ratingRows = [];
    private Dictionary<string, string> _names = [];
    private string _error = "";

    protected override async Task OnInitializedAsync()
    {
        await Load();
        _loaded = true;
    }

    private async Task ImportAll()
    {
        _busy = true;
        _error = "";
        try
        {
            _report = await Importer.ImportAllAsync();
            await Load();
            Snackbar.Add("CSV data imported.", Severity.Success);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add("Could not import CSV data.", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RefreshApi()
    {
        _apiBusy = true;
        _error = "";
        try
        {
            _apiReport = await Api.RefreshFixturesAsync();
            await Load();
            Snackbar.Add(_apiReport.Errors.Count > 0 ? "API refresh completed with warnings." : "API-Football matches refreshed.", _apiReport.Errors.Count > 0 ? Severity.Warning : Severity.Success);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add("Could not refresh API-Football.", Severity.Error);
        }
        finally
        {
            _apiBusy = false;
        }
    }

    private async Task RefreshRankings()
    {
        _rankingsBusy = true;
        _error = "";
        try
        {
            _rankingsReport = await Rankings.RefreshAsync();
            if (_rankingsReport.AnyFileUpdated)
                _ratings = await Importer.ImportRatingsOnlyAsync();
            await Load();
            Snackbar.Add(_rankingsReport.Errors.Count > 0 ? "Ranking refresh completed with warnings." : "Rankings refreshed.", _rankingsReport.Errors.Count > 0 ? Severity.Warning : Severity.Success);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add("Could not refresh rankings.", Severity.Error);
        }
        finally
        {
            _rankingsBusy = false;
        }
    }

    private async Task RefreshAvailability()
    {
        _availabilityBusy = true;
        _error = "";
        try
        {
            _availabilityReport = await Availability.RefreshAsync();
            _roleReport = await Api.EnrichAvailabilityRolesAsync();
            await Load();
            Snackbar.Add(_availabilityReport.Errors.Count > 0 ? "Availability refresh completed with warnings." : "Availability refreshed.", _availabilityReport.Errors.Count > 0 ? Severity.Warning : Severity.Success);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add("Could not refresh availability.", Severity.Error);
        }
        finally
        {
            _availabilityBusy = false;
        }
    }

    private async Task Load()
    {
        _teams = await Db.Teams.CountAsync();
        _fixtures = await Db.Fixtures.CountAsync();
        _ratings = await Db.Ratings.CountAsync();
        _names = await Db.Teams.ToDictionaryAsync(t => t.Id, t => t.Name);
        _ratingRows = await Db.Ratings.OrderByDescending(r => r.Value).Take(40).ToListAsync();
    }

    private string Name(string id) => _names.TryGetValue(id, out var name) ? name : id;
}
