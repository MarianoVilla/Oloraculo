@page "/tournament/snapshots"
@rendermode InteractiveServer
@inject SnapshotService Snapshots
@inject OloraculoDbContext Db
@inject ISnackbar Snackbar

<PageTitle>Tournament snapshots</PageTitle>

<MudStack Spacing="3">
    <div class="page-head">
        <MudText Typo="Typo.h3">Tournament snapshots</MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary">Saved Monte Carlo simulations for reviewing earlier projections without rerunning the tournament.</MudText>
    </div>

    <MudPaper Class="surface-card" Elevation="0">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="action-row">
            <MudText Typo="Typo.h6">Saved snapshots</MudText>
            <MudSpacer />
            <MudButton Href="tournament" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.EmojiEvents">Back to tournament</MudButton>
            <MudTooltip Text="Refresh snapshots">
                <MudIconButton Icon="@Icons.Material.Filled.Refresh" Color="Color.Primary" Disabled="_loadingSnapshot" OnClick="RefreshSnapshots" />
            </MudTooltip>
        </MudStack>
        @if (!_snapshotsLoaded)
        {
            <MudSkeleton Height="34px" Class="skeleton-row" />
            <MudSkeleton Height="34px" Class="skeleton-row" />
        }
        else if (_snapshots.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">No saved tournament snapshots yet.</MudAlert>
        }
        else
        {
            <MudTable Items="_snapshots" Dense="true" Hover="true" Elevation="0" Class="dense-table">
                <HeaderContent>
                    <MudTh>Date</MudTh>
                    <MudTh>Model</MudTh>
                    <MudTh Class="num">Simulations</MudTh>
                    <MudTh>Hash</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Date">@context.CreatedAt.ToLocalTime().ToString("g")</MudTd>
                    <MudTd DataLabel="Model">@context.ModelName</MudTd>
                    <MudTd DataLabel="Simulations" Class="num">@(context.Simulations?.ToString("N0") ?? "-")</MudTd>
                    <MudTd DataLabel="Hash">@ShortHash(context.InputSummaryHash)</MudTd>
                    <MudTd DataLabel="Status">
                        @if (context.IsValid)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">Ready</MudChip>
                        }
                        else
                        {
                            <MudTooltip Text="@context.Error">
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">Unavailable</MudChip>
                            </MudTooltip>
                        }
                    </MudTd>
                    <MudTd Class="action-cell">
                        <MudButton Size="Size.Small"
                                   Variant="Variant.Outlined"
                                   Color="@(_activeSnapshotId == context.Id ? Color.Primary : Color.Default)"
                                   StartIcon="@Icons.Material.Filled.Visibility"
                                   Disabled="_loadingSnapshot || !context.IsValid"
                                   OnClick="@(() => LoadSnapshot(context))">
                            @(_activeSnapshotId == context.Id ? "Viewing" : "View")
                        </MudButton>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudPaper>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_error</MudAlert>
    }

    @if (_projection is not null)
    {
        <MudPaper Class="surface-card" Elevation="0">
            <MudText Typo="Typo.h6">Championship probability</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">@_projectionSource | @_projection.Simulations.ToString("N0") simulations | @_projection.InputSummaryHash</MudText>
            <MudTable Items="_projection.Teams.Take(32)" Dense="true" Hover="true" Elevation="0" Class="dense-table">
                <HeaderContent>
                    <MudTh>Team</MudTh>
                    <MudTh Class="num">Qualify</MudTh>
                    <MudTh Class="num">R32</MudTh>
                    <MudTh Class="num">QF</MudTh>
                    <MudTh Class="num">Semis</MudTh>
                    <MudTh Class="num">Final</MudTh>
                    <MudTh Class="num">Champion</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Team"><TeamLabel TeamId="@context.TeamId" Name="@Name(context.TeamId)" /></MudTd>
                    <MudTd DataLabel="Qualify" Class="num">@context.Qualify.ToString("P0")</MudTd>
                    <MudTd DataLabel="R32" Class="num">@context.ReachRoundOf16.ToString("P0")</MudTd>
                    <MudTd DataLabel="QF" Class="num">@context.ReachQuarterFinal.ToString("P0")</MudTd>
                    <MudTd DataLabel="Semis" Class="num">@context.ReachSemiFinal.ToString("P0")</MudTd>
                    <MudTd DataLabel="Final" Class="num">@context.ReachFinal.ToString("P0")</MudTd>
                    <MudTd DataLabel="Champion" Class="num"><strong>@context.WinTournament.ToString("P1")</strong></MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }
</MudStack>

@code {
    private bool _loadingSnapshot;
    private bool _snapshotsLoaded;
    private string _error = "";
    private string _projectionSource = "";
    private int? _activeSnapshotId;
    private TournamentProjection? _projection;
    private IReadOnlyList<TournamentSnapshotSummary> _snapshots = [];
    private Dictionary<string, string> _names = [];

    protected override async Task OnInitializedAsync()
    {
        _names = await Db.Teams.ToDictionaryAsync(t => t.Id, t => t.Name);
        await RefreshSnapshots();
    }

    private async Task RefreshSnapshots()
    {
        _snapshotsLoaded = false;
        try
        {
            _snapshots = await Snapshots.TournamentSnapshotsAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
                Snackbar.Add("Could not load snapshots.", Severity.Error);
        }
        finally
        {
            _snapshotsLoaded = true;
        }
    }

    private async Task LoadSnapshot(TournamentSnapshotSummary summary)
    {
        if (!summary.IsValid)
        {
            Snackbar.Add(summary.Error ?? "The snapshot is not available.", Severity.Warning);
            return;
        }

        _loadingSnapshot = true;
        _error = "";
        try
        {
            var result = await Snapshots.LoadTournamentSnapshotAsync(summary.Id);
            if (!result.IsValid || result.Projection is null)
            {
                _error = result.Error ?? "Could not read the snapshot.";
                Snackbar.Add(_error, Severity.Error);
                return;
            }

            _projection = result.Projection;
            _projectionSource = $"Saved snapshot {summary.CreatedAt.ToLocalTime():g}";
            _activeSnapshotId = summary.Id;
            Snackbar.Add("Snapshot loaded.", Severity.Success);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add("Could not load the snapshot.", Severity.Error);
        }
        finally
        {
            _loadingSnapshot = false;
        }
    }

    private string Name(string id) => _names.TryGetValue(id, out var name) ? name : id;

    private static string ShortHash(string hash) =>
        string.IsNullOrWhiteSpace(hash) ? "-" : hash[..Math.Min(12, hash.Length)];
}
