ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080

# SQLite hot-state volume. Permanent market-data history belongs in object storage.
ConnectionStrings__Oloraculo=Data Source=/var/oloraculo/oloraculo.db
Oloraculo__RankingRefreshOnStartup=false

# R2/S3-compatible archive. Provide values in AWS Parameter Store, Secrets Manager,
# App Runner env vars, ECS task secrets, or the EC2 instance environment.
Oloraculo__ObjectArchive__Enabled=false
Oloraculo__ObjectArchive__Provider=R2
Oloraculo__ObjectArchive__Prefix=oloraculo
Oloraculo__ObjectArchive__ForcePathStyle=true
Oloraculo__ObjectArchive__BucketEnvironmentVariable=OLORACULO_R2_BUCKET
Oloraculo__ObjectArchive__EndpointEnvironmentVariable=OLORACULO_R2_ENDPOINT
Oloraculo__ObjectArchive__RegionEnvironmentVariable=AWS_REGION
Oloraculo__ObjectArchive__AccessKeyIdEnvironmentVariable=OLORACULO_R2_ACCESS_KEY_ID
Oloraculo__ObjectArchive__SecretAccessKeyEnvironmentVariable=OLORACULO_R2_SECRET_ACCESS_KEY

OLORACULO_R2_BUCKET=<provided separately>
OLORACULO_R2_ENDPOINT=<provided separately>
AWS_REGION=auto
OLORACULO_R2_ACCESS_KEY_ID=<provided separately>
OLORACULO_R2_SECRET_ACCESS_KEY=<provided separately>
