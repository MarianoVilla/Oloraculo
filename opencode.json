{
  "$schema": "https://opencode.ai/config.json",
  "shell": "pwsh",
  "share": "disabled",
  "autoupdate": "notify",
  "default_agent": "chief-systems-architect",
  "instructions": [
    "AGENTS.md",
    "CLAUDE.md",
    ".claude/README.md",
    "docs/source-of-truth/ACTIVE.md",
    "docs/source-of-truth/COMMANDS.md",
    "docs/source-of-truth/DATA_AND_SECRETS.md",
    "docs/source-of-truth/OLORACULO_PRODUCTION_ARCHITECTURE.md",
    "docs/source-of-truth/OLORACULO_PRODUCTION_BACKLOG.md"
  ],
  "skills": {
    "paths": [
      ".claude/skills"
    ]
  },
  "references": {
    "source-of-truth": {
      "path": "docs/source-of-truth",
      "description": "Oloraculo operating context, production architecture, backlog phases, command gates, data/config rules, and cockpit specifications."
    },
    "tests": {
      "path": "Oloraculo.Web.Tests",
      "description": "Expected predictor, probability, service, import, archive, combo, snapshot, and cockpit behavior."
    },
    "rust-hotpath": {
      "path": "rust/oloraculo_hotpath",
      "description": "Deterministic Rust CLOB/scanner math and read-only snapshot contracts."
    },
    "mcp-tooling": {
      "path": "tools/mcp",
      "description": "Project MCP server, local MCP examples, and smoke tests."
    }
  },
  "mcp": {
    "oloraculo-context": {
      "type": "local",
      "command": [
        "python",
        "tools/mcp/oloraculo_context_server.py"
      ],
      "cwd": ".",
      "enabled": true,
      "timeout": 30000
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "timeout": 30000
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--isolated",
        "--headless",
        "--no-usage-statistics",
        "--no-performance-crux",
        "--redactNetworkHeaders"
      ],
      "enabled": true,
      "timeout": 60000
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--isolated",
        "--browser=chromium",
        "--headless",
        "--block-service-workers",
        "--allowed-origins=http://localhost:*;https://localhost:*"
      ],
      "enabled": true,
      "timeout": 60000
    },
    "serena": {
      "type": "local",
      "command": [
        "C:\\Users\\gianz\\.local\\bin\\serena.exe",
        "start-mcp-server",
        "--context",
        "ide",
        "--language-backend",
        "LSP",
        "--project-from-cwd"
      ],
      "cwd": ".",
      "environment": {
        "PYTHONIOENCODING": "utf-8",
        "PYTHONUTF8": "1"
      },
      "enabled": true,
      "timeout": 60000
    },
    "firecrawl-research": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "firecrawl-mcp"
      ],
      "enabled": false,
      "timeout": 60000
    },
    "dbhub-oloraculo": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@bytebase/dbhub@latest",
        "--transport",
        "stdio",
        "--config",
        "tools/mcp/dbhub.local.toml"
      ],
      "enabled": false,
      "timeout": 60000
    },
    "github-readonly": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "-e",
        "GITHUB_TOOLSETS=repos,issues,pull_requests,actions,code_security",
        "ghcr.io/github/github-mcp-server",
        "--read-only"
      ],
      "enabled": false,
      "timeout": 60000
    },
    "grafana-readonly": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-grafana",
        "--disable-write",
        "--disable-admin",
        "--disable-incident",
        "--disable-oncall",
        "--disable-sift",
        "--disable-snapshot",
        "--disable-alerting"
      ],
      "enabled": false,
      "timeout": 60000
    },
    "prometheus-readonly": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-e",
        "PROMETHEUS_URL",
        "-e",
        "PROMETHEUS_TOKEN",
        "-e",
        "PROMETHEUS_DISABLE_LINKS=True",
        "-e",
        "PROMETHEUS_REQUEST_TIMEOUT=30",
        "ghcr.io/pab1it0/prometheus-mcp-server:latest"
      ],
      "enabled": false,
      "timeout": 60000
    },
    "sentry-readonly": {
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp",
      "oauth": {},
      "enabled": false,
      "timeout": 60000
    },
    "aws-docs": {
      "type": "local",
      "command": [
        "uvx",
        "awslabs.aws-documentation-mcp-server@latest"
      ],
      "environment": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "AWS_DOCUMENTATION_PARTITION": "aws"
      },
      "enabled": false,
      "timeout": 60000
    }
  },
  "permission": {
    "read": "allow",
    "edit": "allow",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "rg *": "allow",
      "dotnet restore*": "allow",
      "dotnet build*": "allow",
      "dotnet test*": "allow",
      "cargo test*": "allow",
      "python tooling\\goal_strength_calibration.py*": "allow",
      "python tools\\mcp\\test_oloraculo_context_server.py*": "allow",
      "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/opencode/check-oloraculo-opencode.ps1*": "allow",
      "git reset*": "deny",
      "git clean*": "deny",
      "git checkout --*": "deny",
      "git push --force*": "deny",
      "git push -f*": "deny",
      "rm *": "deny",
      "Remove-Item*": "deny"
    },
    "skill": "allow",
    "todowrite": "allow",
    "question": "allow",
    "webfetch": "allow",
    "external_directory": {
      "*": "ask",
      "C:\\Users\\gianz\\AppData\\Local\\Temp\\opencode\\**": "allow"
    }
  },
  "tool_output": {
    "max_lines": 2500,
    "max_bytes": 65536
  },
  "compaction": {
    "auto": true,
    "tail_turns": 10
  },
  "experimental": {
    "mcp_timeout": 30000
  }
}
